{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "status", "submitted", "version", "build", "appStoreConnect", "submittedAt", "acceptedAt", "lastCheckedAt", "exportCompliance"],
  "properties": {
    "schemaVersion": {"const": 1},
    "status": {"const": "draft"},
    "submitted": {"const": false},
    "version": {"const": "1.1"},
    "build": {"const": 2},
    "appStoreConnect": {
      "type": "object",
      "additionalProperties": false,
      "required": ["appId", "versionId", "buildId", "submissionId"],
      "properties": {
        "appId": {"type": "null"},
        "versionId": {"type": "null"},
        "buildId": {"type": "null"},
        "submissionId": {"type": "null"}
      }
    },
    "submittedAt": {"type": "null"},
    "acceptedAt": {"type": "null"},
    "lastCheckedAt": {"type": "null"},
    "exportCompliance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["usesEncryption", "exempt", "basis"],
      "properties": {
        "usesEncryption": {"const": true},
        "exempt": {"const": true},
        "basis": {"const": "standard-https"}
      }
    }
  }
}
