{
  "schemaVersion": 1,
  "version": "1.1",
  "build": 2,
  "tracking": false,
  "analytics": false,
  "dataSharedWithThirdParties": false,
  "localOnlyProcessing": ["camera-frames", "photo-crops", "embeddings", "live-candidate-set", "identifier-caches", "submission-drafts"],
  "transmittedOnlyOnExplicitSightingSubmission": ["contact-email", "chosen-location", "submitted-content", "attached-photo", "selected-catalog-id", "similarity-score", "score-semantics", "manifest-version", "model-version", "index-version", "up-to-five-reference-photo-ids"],
  "transmittedOnOptionalAccountUse": ["name", "account-email", "user-id"],
  "transmittedForAppleAuthentication": ["apple-identity-token", "apple-authorization-code"],
  "collectedData": [
    {"dataType": "email-address", "linkedToUser": true, "purpose": "app-functionality", "tracking": false},
    {"dataType": "name", "linkedToUser": true, "purpose": "app-functionality", "tracking": false},
    {"dataType": "photos-or-videos", "linkedToUser": true, "purpose": "app-functionality", "tracking": false},
    {"dataType": "coarse-location", "linkedToUser": true, "purpose": "app-functionality", "tracking": false},
    {"dataType": "user-id", "linkedToUser": true, "purpose": "app-functionality", "tracking": false},
    {"dataType": "other-user-content", "linkedToUser": true, "purpose": "app-functionality", "tracking": false}
  ],
  "networkDisclosure": "The live candidate set stays local. Explicit sighting submission sends its contact email, user-chosen location and content, attached photo, and selected suggestion evidence: catalog ID, similarity score and score semantics, manifest/model/index versions, and up to five reference-photo IDs. Optional account use separately sends Name, account email, and User ID. Sign in with Apple separately sends the Apple identity token and one-use authorization code for authentication. Camera frames, crops, embeddings, caches, drafts, and unselected candidates stay on device."
}
